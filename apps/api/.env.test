# Test Environment
NODE_ENV=test
LOG_LEVEL=error

# Server
PORT=3002
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# Database (Test Database)
DATABASE_URL=postgresql://shorly:shorly_password@localhost:5432/shorly_test
DB_POOL_MIN=1
DB_POOL_MAX=5

# Redis (Test)
REDIS_URL=redis://localhost:6379/1
REDIS_TOKEN=
REDIS_TTL=3600

# JWT (Test Secrets)
JWT_SECRET=test-jwt-secret-for-testing-purposes-only-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test-refresh-secret-for-testing-purposes-only-different
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000
