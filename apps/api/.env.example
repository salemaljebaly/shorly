# Environment
NODE_ENV=development
LOG_LEVEL=info

# Server
PORT=3001
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (for Docker Compose)
POSTGRES_USER=shorly
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=shorly

# Database
DATABASE_URL=postgresql://shorly:change-this-password@localhost:5432/shorly
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=
REDIS_TTL=3600

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-must-be-different-from-jwt-secret
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
