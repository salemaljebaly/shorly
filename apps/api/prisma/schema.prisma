// Prisma Schema for shorly

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= Role Model =============
model Role {
  id          String   @id @default(cuid())
  name        String   @unique // SUPER_ADMIN, ADMIN, SUPERVISOR, USER
  description String?
  permissions Json // Array of permission strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("roles")
}

// ============= User Model =============
model User {
  id                 String           @id @default(cuid())
  email              String           @unique
  name               String?
  password           String
  apiKey             String?          @unique
  refreshToken       String?          @unique
  avatar             String?
  bio                String?
  location           String?
  website            String?
  timezone           String?          @default("UTC")
  language           String?          @default("en")
  emailNotifications Boolean          @default(true)
  analyticsTracking  Boolean          @default(true)
  isActive           Boolean          @default(true)
  plan               SubscriptionPlan @default(FREE)

  // RBAC fields
  roleId           String? // Foreign key to roles table
  role             Role?     @relation(fields: [roleId], references: [id])
  suspendedAt      DateTime? // When user was suspended
  suspendedBy      String? // Admin ID who suspended the user
  suspensionReason String? // Reason for suspension

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  links        Link[]
  oneLinks     OneLink[]
  adminLogs    AdminLog[]
  subscription Subscription?

  @@index([email])
  @@index([apiKey])
  @@index([refreshToken])
  @@index([roleId])
  @@map("users")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
}

// ============= Link Model =============
model Link {
  id             String    @id @default(cuid())
  shortCode      String    @unique
  destinationUrl String
  title          String?
  description    String?
  tags           String[]
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  userId         String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks ClickEvent[]

  @@index([shortCode])
  @@index([userId])
  @@index([isActive])
  @@map("links")
}

// ============= OneLink Model =============
model OneLink {
  id          String   @id @default(cuid())
  shortCode   String   @unique
  title       String?
  description String?
  targets     Json // Array of OneLinkTarget objects
  fallbackUrl String
  isActive    Boolean  @default(true)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks ClickEvent[]

  @@index([shortCode])
  @@index([userId])
  @@index([isActive])
  @@map("onelinks")
}

// ============= Analytics Model =============
model ClickEvent {
  id        String   @id @default(cuid())
  linkId    String?
  oneLinkId String?
  timestamp DateTime @default(now())
  ip        String?
  userAgent String?
  referer   String?
  country   String?
  city      String?
  device    String?
  browser   String?
  os        String?

  link    Link?    @relation(fields: [linkId], references: [id], onDelete: Cascade)
  oneLink OneLink? @relation(fields: [oneLinkId], references: [id], onDelete: Cascade)

  @@index([linkId, timestamp])
  @@index([oneLinkId, timestamp])
  @@index([timestamp])
  @@map("click_events")
}

// ============= Admin Log Model =============
model AdminLog {
  id         String   @id @default(cuid())
  adminId    String // Foreign key to users table
  action     String // Action performed (VIEW_USER, EDIT_USER, etc.)
  targetId   String? // ID of affected resource
  targetType String? // Type of resource (USER, SUBSCRIPTION, etc.)
  metadata   Json? // Additional context
  ipAddress  String? // IP address of admin
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([targetId, targetType])
  @@map("admin_logs")
}

// ============= Subscription Model (Future: Billing) =============
model Subscription {
  id     String             @id @default(cuid())
  userId String             @unique
  plan   SubscriptionPlan   @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  // Provider fields (for billing integration)
  provider           String? // paypal, paddle, stripe, manual
  providerId         String? // External subscription ID
  providerCustomerId String? // External customer ID

  // Period tracking
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  // Metadata for provider-specific data
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([providerId])
  @@index([status])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  PAUSED
}
